{
  "name": "rakshak-server",
  "version": "1.0.0",
  "description": "Rakshak microservices backend - Docker Compose orchestration",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:parallel": "docker compose up --build",
    "start": "docker compose up -d",
    "build": "docker compose build",
    "stop": "docker compose down",
    "logs": "docker compose logs -f",
    "status": "docker compose ps",
    "clean": "docker compose down -v --rmi local"
  },
  "engines": {
    "node": ">=18"
  }
}
